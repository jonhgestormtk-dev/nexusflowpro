rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * NexusFlow Pro Security Rules - Versão de Desenvolvimento
     * 
     * Para garantir que você não seja bloqueado durante o prototipagem,
     * as regras foram simplificadas para permitir acesso total a usuários logados.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Regras Gerais: Usuários logados podem ler e escrever em quase tudo
    // Isso evita erros de "Missing or insufficient permissions" durante os testes.

    match /users/{userId} {
      allow read, write: if isOwner(userId) || (isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)));
      
      match /notifications/{notificationId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /roles_admin/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) || (isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)));
    }

    match /clients/{clientId} {
      allow read, write: if isSignedIn();
    }

    match /contracts/{contractId} {
      allow read, write: if isSignedIn();
    }

    match /invoices/{invoiceId} {
      allow read, write: if isSignedIn();
    }

    match /payments/{paymentId} {
      allow read, write: if isSignedIn();
    }

    match /crmLeads/{leadId} {
      allow read, write: if isSignedIn();
    }

    match /scheduleEntries/{scheduleEntryId} {
      allow read, write: if isSignedIn();
    }

    match /companySettings/{settingsId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /services/{serviceId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /uploads/{uploadId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn();
    }

    match /activityLogs/{activityId} {
      allow read, create: if isSignedIn();
      allow update, delete: if false;
    }
  }
}