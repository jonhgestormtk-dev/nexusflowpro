rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * NexusFlow Pro Security Rules
     * 
     * Modelo ajustado para prototipagem rápida:
     * - Leitura (get/list) permitida para qualquer usuário logado em entidades globais.
     * - Escrita (create/update/delete) restrita por papéis (Admin, Financeiro, Comercial).
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isFinanceiro() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_financeiro/$(request.auth.uid));
    }

    function isComercial() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_comercial/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isInternalStaff() {
      return isAdmin() || isFinanceiro() || isComercial();
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if (isOwner(userId) || isAdmin()) && resource != null;
      allow delete: if isAdmin() && resource != null;

      match /notifications/{notificationId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isOwner(userId) && resource != null;
        allow delete: if isOwner(userId) && resource != null;
      }
    }

    match /roles_admin/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      allow update, delete: if isAdmin();
    }
    match /roles_financeiro/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      allow update, delete: if isAdmin();
    }
    match /roles_comercial/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      allow update, delete: if isAdmin();
    }

    match /companySettings/{settingsId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /services/{serviceId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }

    match /clients/{clientId} {
      allow get, list: if isSignedIn();
      allow create, update: if isInternalStaff();
      allow delete: if isAdmin();
    }

    match /contracts/{contractId} {
      allow get, list: if isSignedIn();
      allow create: if isInternalStaff();
      allow update: if isInternalStaff();
      allow delete: if isAdmin();
    }

    match /invoices/{invoiceId} {
      allow get, list: if isSignedIn();
      allow create, update: if isAdmin() || isFinanceiro();
      allow delete: if isAdmin();
    }

    match /payments/{paymentId} {
      allow get, list: if isSignedIn();
      allow create: if isAdmin() || isFinanceiro();
      allow update, delete: if isAdmin();
    }

    match /uploads/{uploadId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.uploadedByUserId == request.auth.uid;
      allow update, delete: if isAdmin() || (resource != null && resource.data.uploadedByUserId == request.auth.uid);
    }

    match /activityLogs/{activityId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    match /crmLeads/{leadId} {
      allow get, list: if isSignedIn();
      allow create: if isAdmin() || isComercial();
      allow update: if isAdmin() || (resource != null && resource.data.assignedToUserId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /scheduleEntries/{scheduleEntryId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isAdmin() || (resource != null && request.auth.uid in resource.data.assignedToUserIds);
      allow delete: if isAdmin();
    }
  }
}